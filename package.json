{
  "name": "fluxbooks-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/desktop-tray/ui",
    "tools/mock-ws-server"
  ],
  "scripts": {
    "dev": "npm run dev -w @fluxbooks/desktop-tray-ui",
    "build": "npm run build -w @fluxbooks/desktop-tray-ui",
    "preview": "npm run preview -w @fluxbooks/desktop-tray-ui",
    "tauri": "tauri",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:e2e": "npm run test:e2e -w @fluxbooks/desktop-tray-ui",
    "mock:ws": "node tools/mock-ws-server/server.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@typescript-eslint/parser": "^8.61.1",
    "@vue/eslint-config-typescript": "^14.8.0",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.1"
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs,json,css,md}": [
      "prettier --write"
    ],
    "*.{ts,vue}": [
      "eslint --fix"
    ],
    "*.rs": [
      "cargo fmt --manifest-path apps/desktop-tray/src-tauri/Cargo.toml --"
    ]
  }
}
